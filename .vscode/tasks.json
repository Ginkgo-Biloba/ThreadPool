{
// Consultez https://go.microsoft.com/fwlink/?LinkId=733558 
	// pour voir la documentation sur le format de tasks.json
	"version": "2.0.0",
	"tasks": [
		{
			"label": "mingw64",
			"type": "process",
			"command": "${env:mingw}\\bin\\g++.exe",
			"args": [
				"-D_WIN32_WINNT=_WIN32_WINNT_WIN6",
				"-std=c++11",
				"-Wall",
				"-Wextra",
				"-Wpedantic",
				"-Wcast-align",
				"-Wconversion",
				"-Wpointer-arith",
				"-Wshadow",
				"-Wno-format",
				// "-Wshadow-field",
				// "-fsanitize=undefined",
				"-g",
				"-O1",
				"-o",
				"ThreadPool.exe",
				"-msse4.2",
				"ThreadPool\\main.cpp",
				"ThreadPool\\syncpool.cpp",
				"ThreadPool\\asyncpool.cpp",
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": true,
				"clear": false
			},
			"problemMatcher": "$gcc"
		}
	]
}
