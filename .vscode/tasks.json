{
// Consultez https://go.microsoft.com/fwlink/?LinkId=733558 
	// pour voir la documentation sur le format de tasks.json
	"version": "2.0.0",
	"tasks": [
		{
			"label": "thread",
			"type": "process",
			"command": "${env:mingw}/bin/g++.exe",
			"args": [
				"-std=c++11",
				"-Wall",
				"-Wextra",
				"-pedantic",
				"-Wcast-align",
				"-Wconversion",
				"-Wformat-nonliteral",
				"-Wpointer-arith",
				"-Wshadow",
				// "-fsanitize=undefined",
				// "-g",
				"-O2",
				"-msse4.2",
				"ThreadPool/main.cpp",
				"ThreadPool/threadpool.cpp",
				"-o",
				"x64_Debug/main.exe",
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": true,
				"clear": false
			},
			"problemMatcher": "$gcc"
		}
	]
}
